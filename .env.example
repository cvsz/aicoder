# ZAI Coder CLI — environment configuration
# Copy this file to .env and fill in your keys.

# Required for all Claude API features.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional. Only needed for --embed / --embed-file / --embed-similarity
# (claude_embeddings.py). Anthropic does not host its own embedding model;
# these commands call Voyage AI, Anthropic's documented embeddings partner.
# Get a key at https://dashboard.voyageai.com
VOYAGE_API_KEY=

# Optional. Only needed if you use --gh-* (claude_github.py) commands.
GITHUB_TOKEN=
